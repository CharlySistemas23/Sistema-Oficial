{
  "name": "opal-frontend",
  "version": "1.0.0",
  "description": "Frontend Opal & Co - servir localmente para evitar errores con file://",
  "scripts": {
    "serve": "npx --yes serve . -l 3000",
    "start": "npx --yes serve . -l 3000",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "audit:local": "playwright test tests/e2e/local-audit.spec.js",
    "audit:modules": "playwright test tests/e2e/all-modules-e2e.spec.js",
    "audit:nightly": "playwright test tests/e2e/all-modules-e2e.spec.js --reporter=list",
    "audit:domain:sales": "playwright test tests/e2e/domains/sales-domain.e2e.spec.js",
    "audit:domain:inventory": "playwright test tests/e2e/domains/inventory-domain.e2e.spec.js",
    "audit:domain:cash": "playwright test tests/e2e/domains/cash-domain.e2e.spec.js",
    "audit:domain:reports": "playwright test tests/e2e/domains/reports-domain.e2e.spec.js",
    "audit:domains": "playwright test tests/e2e/domains",
    "audit:nightly:domains": "playwright test tests/e2e/domains --reporter=list"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.2"
  }
}
